
echo "FROM python:3.10-slim

WORKDIR /app

COPY requirements.txt /app/
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY src/ /app/src/

ENV KAFKA_BOOTSTRAP_SERVERS=kafka1:29091,kafka2:29092,kafka3:29093

ENTRYPOINT [\"python\", \"/app/src/producer.py\"]
CMD [\"--count\", \"500\", \"--rate\", \"10\", \"--source\", \"docker-site\"]" > Dockerfile.producer